# Database – use a free online PostgreSQL (no local SQL/server needed)
# Neon (recommended): https://neon.tech → Create project → copy connection string
# Supabase: https://supabase.com → New project → Settings → Database → Connection string (URI)
# Example (Neon):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Session (use a long random string in production)
SESSION_SECRET="your-session-secret-min-32-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Football data (optional; for schedule and statistics sync)
FOOTBALL_DATA_ORG_API_KEY=""

# Optional ScoreAxis overrides for official widget pairing.
# Use JSON objects with string keys and string values.
# Example:
# NEXT_PUBLIC_SCOREAXIS_MATCH_IDS_JSON="{\"552049\":\"replace-with-scoreaxis-match-id\"}"
# NEXT_PUBLIC_SCOREAXIS_LEAGUE_IDS_JSON="{\"super lig\":\"replace-with-scoreaxis-league-id\"}"
# NEXT_PUBLIC_SCOREAXIS_TEAM_IDS_JSON="{\"afc ajax\":\"replace-with-scoreaxis-team-id\"}"
NEXT_PUBLIC_SCOREAXIS_MATCH_IDS_JSON=""
NEXT_PUBLIC_SCOREAXIS_LEAGUE_IDS_JSON=""
NEXT_PUBLIC_SCOREAXIS_TEAM_IDS_JSON=""
